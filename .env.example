# ── Database ──────────────────────────────────────────────────────────────────
MONGO_USER=slms
MONGO_PASSWORD=slmspassword
POSTGRES_USER=slms
POSTGRES_PASSWORD=slmspassword

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Alerting ──────────────────────────────────────────────────────────────────
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-smtp-app-password
ALERT_FROM=slms-alerts@yourdomain.com
ALERT_TO=admin@yourdomain.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── GeoIP ─────────────────────────────────────────────────────────────────────
MAXMIND_LICENSE_KEY=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_GEOIP=false
ENABLE_TELEGRAM=false
ENABLE_EMAIL=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ML ────────────────────────────────────────────────────────────────────────
ML_CONTAMINATION=0.05
ML_RETRAIN_INTERVAL_HOURS=6
